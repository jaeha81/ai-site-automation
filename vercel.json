{
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/revenue-sync",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 60
    },
    "src/app/api/cron/**": {
      "maxDuration": 300
    }
  }
}
