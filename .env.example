# ══════════════════════════════════════════════
# 쇼핑숏츠 자율수익화 시스템 — 환경변수 목록
# 복사: cp .env.example .env.local
# Vercel: Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════

# ──────────────────────────────────────────────
# [필수] Turso (LibSQL) 데이터베이스
# https://turso.tech → 무료 플랜 사용 가능
# ──────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ──────────────────────────────────────────────
# [필수] Google Gemini AI API (콘텐츠 자동 생성)
# https://aistudio.google.com/apikey
# 모델: gemini-2.5-flash / API 버전: v1beta
# ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ──────────────────────────────────────────────
# [필수] Cron 보안 키
# 생성: openssl rand -base64 32
# Vercel Cron Authorization 헤더에 Bearer <값> 형태로 사용
# ──────────────────────────────────────────────
CRON_SECRET=your-random-secret-32chars

# ──────────────────────────────────────────────
# [필수] 쿠팡 파트너스 API (한국 어필리에이트)
# https://partners.coupang.com → 마이페이지 → API 연동
# ──────────────────────────────────────────────
COUPANG_ACCESS_KEY=your-coupang-access-key
COUPANG_SECRET_KEY=your-coupang-secret-key

# ──────────────────────────────────────────────
# [선택] YouTube Data API v3 (Shorts 자동 업로드)
# 1. https://console.cloud.google.com → YouTube Data API v3 활성화
# 2. OAuth 2.0 클라이언트 ID 생성 (웹 애플리케이션)
# 3. https://developers.google.com/oauthplayground 에서 Refresh Token 발급
#    Scope: https://www.googleapis.com/auth/youtube.upload
# ──────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REFRESH_TOKEN=1//your-refresh-token
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# [선택] Shotstack (AI 영상 자동 생성)
# https://shotstack.io → Dashboard → API Keys
# SHOTSTACK_STAGE: sandbox(무료/워터마크) 또는 production
# ──────────────────────────────────────────────
SHOTSTACK_API_KEY=your-shotstack-api-key
SHOTSTACK_STAGE=sandbox

# ──────────────────────────────────────────────
# [선택] Tistory API (한국 블로그 자동 포스팅)
# https://www.tistory.com/guide/api/manage/register
# ──────────────────────────────────────────────
TISTORY_ACCESS_TOKEN=your-tistory-access-token
TISTORY_BLOG_NAME=your-blog-name

# ──────────────────────────────────────────────
# [선택] Amazon Associates (글로벌 어필리에이트)
# https://affiliate-program.amazon.com
# TARGET_MARKETS: KR,US,JP,GB,DE,AU 중 활성화할 마켓 (쉼표 구분)
# ──────────────────────────────────────────────
TARGET_MARKETS=KR
AMAZON_ASSOCIATE_TAG_US=your-us-tag-20
AMAZON_ASSOCIATE_TAG_JP=your-jp-tag-22
AMAZON_ASSOCIATE_TAG_GB=your-gb-tag-21
AMAZON_ASSOCIATE_TAG_DE=your-de-tag-21
AMAZON_ASSOCIATE_TAG_AU=your-au-tag-22

# ──────────────────────────────────────────────
# [선택] Discord 쇼츠 전용 채널 알림
# ⚠️ jh-chat(Bucky 에이전트 전용)과 분리된 별도 채널 사용 필수
# 채널 설정 → 통합 → 웹훅 → 새 웹훅 생성
# 슬래시 커맨드(/상태 /실행 등): APPLICATION_ID + BOT_TOKEN 추가 필요
# ──────────────────────────────────────────────
SHORTS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
SHORTS_DISCORD_PUBLIC_KEY=your-discord-app-public-key
SHORTS_DISCORD_APPLICATION_ID=your-discord-application-id
SHORTS_DISCORD_BOT_TOKEN=your-discord-bot-token
SHORTS_DISCORD_GUILD_ID=your-discord-guild-id

# ──────────────────────────────────────────────
# [선택] 대시보드 비밀번호 보호
# 미설정 시 기본값 사용 (배포 후 반드시 변경 권장)
# ──────────────────────────────────────────────
DASHBOARD_PASSWORD=your-dashboard-password

# ──────────────────────────────────────────────
# 개발 전용 (Vercel에는 설정 불필요)
# ──────────────────────────────────────────────
# USE_MOCK_DATA=false
# NEXT_PUBLIC_APP_URL=http://localhost:3000
